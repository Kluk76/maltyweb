# BC Online OAuth2 S2S credentials for the maltyweb BC sales-ledger connector.
# Copy this file to config/bc.env and fill in real values.
# config/bc.env is gitignored — never commit the real secret.
#
# How these are used:
#   BC_TENANT_ID     — Azure AD tenant (GUID), used in the OAuth2 token URL
#   BC_CLIENT_ID     — App registration client_id
#   BC_CLIENT_SECRET — App registration client_secret (sensitive)
#   BC_ENVIRONMENT   — BC environment name, e.g. 'Production'
#
# The connector (scripts/python/ingest_bc_sales_ledger.py) reads this file at
# /var/www/maltytask/config/bc.env (same dir as db.env, mode 640, group www-data).
# Override path with env var MALTYTASK_BC_ENV for local testing.

BC_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
BC_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
BC_CLIENT_SECRET=your-client-secret-here
BC_ENVIRONMENT=Production
